# Site (optional; used for canonical URL and OG)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# MongoDB (required for blog)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_DB_NAME=portfolio

# Blog admin (required to create/edit posts via API)
BLOG_ADMIN_SECRET=your-secret-token

# Contact form – Nodemailer (required for contact to work)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_TO_EMAIL=imailfard@gmail.com
